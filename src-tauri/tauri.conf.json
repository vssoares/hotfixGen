{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProjectManager",
  "version": "1.2.2",
  "identifier": "com.projectManager.app",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ProjectManager",
        "width": 900,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "vssoares",
    "windows": {
      "nsis": {}
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxMTk0MkIyMENBQTc5MEUKUldRT2Vhb01za0laMGZpcnBiSVovL3JWNTJRVmFZbVFKRTNyZlpaWlRNY3RSS3o1WmRSOE1ORXAK",
      "endpoints": [
        "https://github.com/vssoares/hotfixGen/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  }
}
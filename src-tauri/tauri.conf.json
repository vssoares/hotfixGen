{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProjectManager",
  "version": "1.0.10",
  "identifier": "com.projectManager.app",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ProjectManager",
        "width": 900,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../task-management.png"],
    "publisher": "vssoares",
    "windows": {
      "nsis": {}
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/vssoares/hotfixGen/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  }
}
